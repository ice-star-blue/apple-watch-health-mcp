{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "watch-health-mcp",
  "main": "src/worker.js",
  "compatibility_date": "2026-07-14",
  "durable_objects": {
    "bindings": [
      {
        "name": "HEALTH_RELAY",
        "class_name": "HealthRelay"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["HealthRelay"]
    }
  ]
}
